{
  "name": "resume-cli",
  "version": "2.1.0",
  "description": "Interactive TUI session picker for AI coding tools (Claude Code, Codex, Copilot).",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "resume": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm test",
    "start": "node dist/cli.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inevolin/resume-cli.git"
  },
  "keywords": [
    "ai",
    "claude",
    "cursor",
    "copilot",
    "codex",
    "mcp",
    "history",
    "context"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/inevolin/resume-cli/issues"
  },
  "homepage": "https://github.com/inevolin/resume-cli#readme",
  "dependencies": {
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.2",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "typescript": "^5.8.3"
  }
}
